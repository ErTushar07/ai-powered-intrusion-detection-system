# 🛡️ AdvancedIDS Custom Rulebase
alert icmp any any -> $HOME_NET any (msg:"GPC: ICMP PING SWEEP DETECTED"; sid:1000001; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"GPC: PORT SCAN DETECTED (SYN)"; flags:S; threshold:type both, track by_src, count 10, seconds 5; sid:1000002; rev:1;)
alert tcp any any -> $HOME_NET [21,22,23,3389] (msg:"GPC: BRUTE FORCE ATTEMPT DETECTED"; threshold:type both, track by_src, count 5, seconds 60; sid:1000003; rev:1;)
